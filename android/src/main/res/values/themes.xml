<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose draws the UI; the XML theme is only the no-action-bar host. Dark
         windowBackground avoids a white flash before Compose's dark theme paints. -->
    <style name="Theme.Titan" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#0B0E14</item>
        <item name="android:statusBarColor">#0B0E14</item>
        <item name="android:navigationBarColor">#0B0E14</item>
    </style>

    <!-- Cold-start splash (AndroidX SplashScreen API): the Titan orb on brand ink, then
         hands off to Theme.Titan once Compose is ready. No artificial delay — it covers
         the real init window. -->
    <style name="Theme.Titan.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0B0E14</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_titan_orb</item>
        <item name="postSplashScreenTheme">@style/Theme.Titan</item>
    </style>
</resources>
