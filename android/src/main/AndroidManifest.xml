<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Reach the Console Agent over Tailscale / nginx-TLS / localhost. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- QR pairing (CameraX-free ZXing scanner). Runtime-requested; optional hardware. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Keep the process un-frozen while a chat reply is in flight / staying connected
         (TitanLinkService). SHORT mode = dataSync; PERSISTENT (always-on) = specialUse
         (no 6 h/24 h cap, unlike dataSync on API 34+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Native "Titan replied" notifications (runtime grant on API 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TitanApp"
        android:allowBackup="false"
        android:label="Titan"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Titan">
        <!-- usesCleartextTraffic: the Tailscale tailnet is WireGuard-encrypted end to end,
             and localhost dev is loopback; the nginx fallback host uses TLS. -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- FGS process anchor for the event channel. SHORT = dataSync (chat reply /
             urgency warm), PERSISTENT = specialUse (opt-in always-connected long-poll). -->
        <service
            android:name=".service.TitanLinkService"
            android:exported="false"
            android:foregroundServiceType="dataSync|specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Maintains the user's own opt-in persistent long-poll link to their self-hosted Titan Console Agent for instant background message delivery without Google services (FCM/GMS), per the no-Google design." />
        </service>

        <!-- The urgency warm-the-line promotes the WorkManager job to a foreground service
             (EventPollWorker.setForeground) → WorkManager's own service must declare the
             dataSync type. tools:node=merge keeps WorkManager's other attributes. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- Channel-2 action-button taps (RFP §7.3 3a) → a headless signed /console/events/
             respond. Not exported: only our own notification PendingIntents trigger it. -->
        <receiver
            android:name=".link.ResponseReceiver"
            android:exported="false" />
    </application>

</manifest>
