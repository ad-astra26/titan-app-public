<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Reach the Console Agent over Tailscale / nginx-TLS / localhost. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- QR pairing (CameraX-free ZXing scanner). Runtime-requested; optional hardware. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <!-- Keep the process un-frozen while a chat reply is in flight (TitanReplyService). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Native "Titan replied" notifications (runtime grant on API 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".TitanApp"
        android:allowBackup="false"
        android:label="Titan"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Titan">
        <!-- usesCleartextTraffic: the Tailscale tailnet is WireGuard-encrypted end to end,
             and localhost dev is loopback; the nginx fallback host uses TLS. -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Short FGS that keeps the in-flight chat reply alive across backgrounding. -->
        <service
            android:name=".service.TitanReplyService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>
